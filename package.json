{
  "name": "academic-translation-pipeline",
  "version": "1.0.0",
  "description": "Automated pipeline for translating and typesetting academic books",
  "main": "render_master.js",
  "scripts": {
    "pipeline": "python3 tools/pipeline.py --action all",
    "render": "python3 tools/pipeline.py --action render",
    "assemble": "python3 tools/pipeline.py --action assemble",
    "audit": "python3 tools/pipeline.py --action audit",
    "check": "python3 tools/pipeline.py --action check",
    "smoke": "python3 tools/pipeline.py --action smoke"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "katex": "^0.16.8",
    "marked": "^12.0.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^22.0.0"
  }
}
